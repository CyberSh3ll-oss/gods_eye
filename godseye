#!/bin/bash

# Color definitions
CYAN='\033[0m\033[36m\033[1m'
GREEN='\033[0m\033[32m'
YELLOW='\033[0m\033[33m'
RED='\033[0m\033[31m'
WHITE='\033[0m\033[37m\033[1m'
RESET='\033[0m'

# Dynamic Header Function
show_header() {
    clear
    echo -e "${CYAN}👁️  ========================================================  👁️"
    echo -e "        ⚡ G O D ' S   E Y E  :  O S I N T   S U I T E ⚡"
    echo -e "               Developed by: Osint_by_vaishnav"
    echo -e " ============================================================${RESET}\n"
}

# Pause helper
pause() {
    echo -e "\n${YELLOW}[*] Action finished. Press Enter to return to menu...${RESET}"
    read
}

# VECTOR 1: RECONNAISANCE
vector_recon() {
    while true; do
        show_header
        echo -e "${CYAN}--- Vector 1: Reconnaissance Sub-Modules ---${RESET}\n"
        echo -e "  ${GREEN}1.${RESET} Bluetooth Assessment (Spooftooph)"
        echo -e "  ${GREEN}2.${RESET} Devices/Host Mapping (Nmap)"
        echo -e "  ${GREEN}3.${RESET} Network Information Gatherer (Dmitry)"
        echo -e "  ${GREEN}4.${RESET} DNS Infrastructure Enumeration (DNSRecon)"
        echo -e "  ${GREEN}5.${RESET} Vulnerability Surface Auditing (Legion)"
        echo -e "  ${GREEN}6.${RESET} Web Server Crawling & Scanning (Nikto)"
        echo -e "  ${GREEN}7.${RESET} Web App Fingerprinting (WhatWeb)"
        echo -e "  ${GREEN}8.${RESET} Wireless / WiFi Inspection (Wifite)"
        echo -e "  ${RED}0.${RESET} Return to Main Control Panel\n"
        echo -n "Launch Application [0-8]: "
        read sub_choice

        case "$sub_choice" in
            1) sudo spooftooph -h ;;
            2) echo -n "Enter Target IP/Domain: "; read target; sudo nmap -v -A "$target"; pause ;;
            3) echo -n "Enter Target Domain: "; read target; dmitry -wnpb "$target"; pause ;;
            4) echo -n "Enter Target Domain: "; read target; dnsrecon -d "$target"; pause ;;
            5) echo -e "\n${YELLOW}[*] Spawning Legion Security Automation Graphical Interface...${RESET}"; legion &>/dev/null & disown; sleep 1 ;;
            6) echo -n "Enter Target Server IP/URL: "; read target; nikto -h "$target"; pause ;;
            7) echo -n "Enter Target URL: "; read target; whatweb "$target"; pause ;;
            8) echo -e "\n${YELLOW}[*] Launching Wifite Wireless Framework...${RESET}"; sudo wifite; pause ;;
            0) break ;;
            *) echo -e "${RED}[!] Option unrecognized.${RESET}"; sleep 1 ;;
        esac
    done
}

