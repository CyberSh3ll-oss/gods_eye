        echo -e "  ${GREEN}1.${RESET} Multi-Protocol Brute Force (Hydra)"
        echo -e "  ${GREEN}2.${RESET} Cryptographic Hash Identification (HashID)"
        echo -e "  ${GREEN}3.${RESET} OS Credential Dumping Tools"
        echo -e "  ${GREEN}4.${RESET} Password Cracking Framework (John the Ripper)"
        echo -e "  ${GREEN}5.${RESET} Password Profiling & Custom Wordlists (CeWL)"
        echo -e "  ${RED}0.${RESET} Return to Main Control Panel\n"
        echo -n "Launch Application [0-5]: "
        read sub_choice

        case "$sub_choice" in
            1) echo -e "\n${YELLOW}[*] Opening Hydra Manual Suite...${RESET}"; hydra -h; pause ;;
            2) echo -n "Paste raw hash string to identify: "; read user_hash; hashid "$user_hash"; pause ;;
            3) echo -e "\n${YELLOW}[*] Checking local system password database security levels...${RESET}"; sudo chntpw -h; pause ;;
            4) echo -e "\n${YELLOW}[*] Initializing John the Ripper environment console...${RESET}"; john; pause ;;
            5) echo -n "Enter Target Web URL to profile text patterns: "; read target; cewl -d 2 -m 5 "$target"; pause ;;
