}

# VECTOR 3: LIVE CHAT WITH HACKER (GEMINI API INTEGRATED)
vector_ai_chat() {
    show_header
    echo -e "${RED}╔════════════════════════════════════════════════════════════════════╗"
    echo -e "║ ⚠️  LEGAL & ETHICAL MANDATE ADVISORY                                ║"
    echo -e "║ This system interface acts strictly as an educational reference   ║"
    echo -e "║ vehicle. All defensive methodologies, syntax definitions, and     ║"
    echo -e "║ auditing logs provided by this AI engine are bound to authorized,  ║"
    echo -e "║ legal, white-hat security exploration protocols exclusively.      ║"
    echo -e "╚════════════════════════════════════════════════════════════════════╝${RESET}\n"
    
    # Check if API Key is actually present in the user environment
    if [ -z "$GEMINI_API_KEY" ]; then
        echo -e "${RED}[!] Error: No GEMINI_API_KEY found in your environment variables.${RESET}"
        echo -e "${YELLOW}[*] Please make sure you ran: export GEMINI_API_KEY=\"your_key_here\"${RESET}"
        pause
        return
    fi

    # Make sure 'jq' utility is installed to process the response text cleanly
    if ! command -v jq &> /dev/null; then
        echo -e "${YELLOW}[*] Installing dependency configuration layer 'jq' for formatting...${RESET}"
        sudo apt update && sudo apt install -y jq &>/dev/null
    fi

    echo -e "${GREEN}[+] God's Eye Security AI Core Online. Connection stable.${RESET}"
    echo -e "${WHITE}Ask any engineering question regarding syntax, defenses, or configurations.${RESET}"
    echo -e "${CYAN}(Type 'exit' or 'back' to disconnect)${RESET}\n"
    
    while true; do
        echo -n -e "${WHITE}HackerShell> ${RESET}"
        read user_query
        
        if [[ "$user_query" == "exit" || "$user_query" == "back" || -z "$user_query" ]]; then
            echo -e "${YELLOW}[*] Severing secure conversational uplink...${RESET}"
            sleep 1
            break
        fi
        
        echo -e "\n${GREEN}[AI Processing Node - Generating Response...]${RESET}"
        
        # Safe escaping of user payload data to valid JSON structure
        json_payload=$(jq -n --arg q "$user_query" '{contents: [{parts: [{text: ($q + " Provide an educational, professional breakdown focused on the mechanics, network configurations, or defensive counter-measures.")}]}]}')

        # Fire request directly to the modern Gemini endpoint
        response=$(curl -s -X POST \
            "https://generativelanguage.googleapis.com/v1beta/models/gemini-1.5-flash:generateContent?key=${GEMINI_API_KEY}" \
            -H "Content-Type: application/json" \
            -d "$json_payload")

        # Parse out and display the content payload text block cleanly
        ai_output=$(echo "$response" | jq -r '.candidates[0].content.parts[0].text' 2>/dev/null)

        if [[ "$ai_output" != "null" && ! -z "$ai_output" ]]; then
            echo -e "${CYAN}${ai_output}${RESET}\n"
        else
            echo -e "${RED}[!] Communication timeout or API refusal. Double-check syntax constraints.${RESET}\n"
        fi
    done
}

# VECTOR 4: AUTOMATED GITHUB INTEGRATION (ZPHISHER)
vector_zphisher() {
    show_header
    echo -e "${CYAN}--- Vector 4: Automated GitHub Deployment ---${RESET}\n"
    echo -e "${YELLOW}[*] Initializing cloud repository pull sequence...${RESET}"
    
    if [ ! -d "zphisher" ]; then
        git clone https://github.com/htr-tech/zphisher.git
    else
        echo -e "${GREEN}[+] Target directory already registered locally. Skipping download.${RESET}"
    fi
    
    if [ -d "zphisher" ]; then
        echo -e "${GREEN}[+] Dynamic build target initialized successfully.${RESET}"
        echo -e "${YELLOW}[*] Shifting execution framework to ZPhisher shell...${RESET}\n"
        cd zphisher
        chmod +x zphisher.sh
        sudo ./zphisher.sh
        cd ..
    else
        echo -e "${RED}[!] Connection to repository endpoint failed.${RESET}"
        pause
    fi
}

# MAIN RUNNER MENU LOOP
while true; do
    show_header
    echo -e "Select an Operational Vector to Begin Blueprint Discovery:\n"
    echo -e "  ${GREEN}1.${RESET} RECONNAISANCE"
    echo -e "  ${GREEN}2.${RESET} CREDENTIAL ACCESS"
    echo -e "  ${GREEN}3.${RESET} CHAT WITH HACKER (Live AI Interface)"
    echo -e "  ${GREEN}4.${RESET} DEPLOY ZPHISHER (Automated Github Tool Builder)"
    echo -e "  ${RED}0.${RESET} Terminate Framework Session (Exit)\n"
    
    echo -n "Execute Vector [0-4]: "
    read main_choice

    case "$main_choice" in
        1) vector_recon ;;
        2) vector_cred_access ;;
        3) vector_ai_chat ;;
        4) vector_zphisher ;;
        0) echo -e "${YELLOW}[*] Shutting down GOD'S EYE mainframe interface. Goodbye.${RESET}"; exit 0 ;;
        *) echo -e "${RED}[!] Vector choice unrecognized.${RESET}"; sleep 1 ;;
    esac
done
